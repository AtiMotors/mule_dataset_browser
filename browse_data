def validate_host(host: str) -> tuple[bool, str]:
    if not host or not host.strip():
        return False, "Host address cannot be empty."
    host = host.strip()
    try:
        ipaddress.ip_address(host)
        return True, ""
    except ValueError:
        pass
    if not re.match(r'^[a-zA-Z0-9]([a-zA-Z0-9\-\.]*[a-zA-Z0-9])?$', host):
        return False, f"Invalid hostname format: '{host}'"
    if len(host) > 253:
        return False, f"Hostname too long: '{host}'"
    return True, ""


def _parse_ssh_error(stderr: str, ip: str) -> str:
    stderr_lower = stderr.lower()
    if "connection refused" in stderr_lower:
        return f"Connection refused. Robot at {ip} may be offline or SSH service not running."
    elif "connection timed out" in stderr_lower or "timed out" in stderr_lower:
        return f"Connection timed out. Check network connectivity to {ip}."
    elif "no route to host" in stderr_lower or "network is unreachable" in stderr_lower:
        return f"Cannot reach {ip}. Check network connection or firewall settings."
    elif "permission denied" in stderr_lower or "authentication failed" in stderr_lower:
        return f"Authentication failed. Check SSH credentials for {ip}."
    elif "host key" in stderr_lower or "hostkey" in stderr_lower:
        return f"Host key verification failed for {ip}. The robot may have been reconfigured."
    elif "name or service not known" in stderr_lower:
        return f"Cannot resolve {ip}. Check the address is correct."
    elif "network is down" in stderr_lower:
        return f"Network is down. Check network interface for {ip}."
    elif not stderr.strip():
        return "Unknown error (empty output). Check network and try again."
    return stderr.strip()


